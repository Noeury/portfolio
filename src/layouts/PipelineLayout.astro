---
import "../styles/global.css";
import "@fontsource-variable/onest";
import { ClientRouter } from "astro:transitions";
import Footer from "../components/Footer.astro";
import PipelineHeader from "../components/PipelineHeader.astro";
import PipelineProgress from "../components/PipelineProgress.astro";

import { HeadHrefLangs } from "astro-i18next/components";
import i18next from "i18next";

interface Props {
  title: string;
  description: string;
  image?: string;
}

const { description, title, image = "/Logo.png" } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin);
---

<!doctype html>
<html lang={i18next.language} class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/Logo.png" />
    <link rel="apple-touch-icon" href="/Logo.png" />

    <!-- Generator -->
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph / Social -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.url.origin)} />
    <meta property="og:locale" content={i18next.language} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.url.origin)} />

    <!-- Performance: preload critical above-the-fold resources -->
    <!-- Preload LCP hero image -->
    <link rel="preload" as="image" href="/Me.jpg" fetchpriority="high" />
    <!-- dns-prefetch as fallback for older browsers -->
    <link rel="dns-prefetch" href="https://www.linkedin.com" />

    <title>{title}</title>
    <ClientRouter />
    <HeadHrefLangs />

    <!-- Theme init — runs before paint to avoid flash -->
    <script is:inline>
      const theme = localStorage.getItem("theme") ?? "dark";
      if (theme === "light") {
        document.documentElement.classList.remove("dark");
      } else {
        document.documentElement.classList.add("dark");
      }
    </script>
  </head>

  <body class="relative text-black dark:text-white">
    <!-- Skip to content for accessibility -->
    <a href="#main-content" class="skip-to-content">Skip to content</a>

    <!-- Background gradient -->
    <div
      class="absolute top-0 bottom-0 z-[-2] min-h-screen w-full bg-gray-50 dark:bg-gray-950
      bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(217,216,255,0.5),rgba(255,255,255,0.9))]
      dark:bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(120,119,198,0.3),rgba(255,255,255,0))]"
      aria-hidden="true"
    >
    </div>

    <!-- Data pipeline grid visual effect in background -->
    <div class="fixed inset-0 z-[-1] opacity-10 dark:opacity-20 pointer-events-none" aria-hidden="true">
      <div class="absolute h-full w-full flex flex-col">
        <div class="h-1/6 border-b border-dashed border-blue-500"></div>
        <div class="h-1/6 border-b border-dashed border-blue-500"></div>
        <div class="h-1/6 border-b border-dashed border-blue-500"></div>
        <div class="h-1/6 border-b border-dashed border-blue-500"></div>
        <div class="h-1/6 border-b border-dashed border-blue-500"></div>
        <div class="h-1/6"></div>
      </div>
      <div class="absolute h-full w-full flex">
        <div class="w-1/5 border-r border-dashed border-blue-500"></div>
        <div class="w-3/5"></div>
        <div class="w-1/5 border-l border-dashed border-blue-500"></div>
      </div>
    </div>

    <!-- Fixed pipeline progress indicator on the left -->
    <PipelineProgress />

    <PipelineHeader />
    <main id="main-content">
      <slot />
    </main>
    <Footer />

    <style is:global>
      @reference "../styles/global.css";

      :root {
        color-scheme: light dark;
      }

      html {
        font-family: "Onest Variable", system-ui, sans-serif;
        scroll-behavior: smooth;
      }

      body {
        color: rgba(17, 17, 17, 0.9);
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        overscroll-behavior: none;
      }

      /* Dark mode body text — class-based (matches theme toggle) */
      html.dark body {
        color: rgba(255, 255, 255, 0.9);
      }

      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }
        *,
        *::before,
        *::after {
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.01ms !important;
        }
      }

      /* ── Pipeline design system ── */
      .pipeline-node {
        @apply relative flex items-center justify-center w-12 h-12 rounded-full border-2 border-blue-500 bg-white dark:bg-gray-900 z-10;
      }

      .pipeline-node.active {
        @apply bg-blue-500 text-white shadow-lg;
      }

      .pipeline-line {
        @apply absolute left-6 w-0.5 h-full -z-10 bg-gradient-to-b from-blue-500 to-gray-300 dark:to-gray-700;
      }

      .pipeline-section {
        @apply relative py-16 transition-all duration-500;
      }

      .pipeline-section-title {
        @apply text-3xl font-bold mb-8 text-blue-700 dark:text-blue-400 tracking-tight flex items-center gap-3;
      }

      .pipeline-content {
        @apply pl-8 lg:pl-12;
      }

      /* Animation for data flowing through the pipeline */
      @keyframes dataflow {
        0% {
          transform: translateY(-10px);
          opacity: 0;
        }
        50% {
          opacity: 1;
        }
        100% {
          transform: translateY(10px);
          opacity: 0;
        }
      }

      .dataflow-dot {
        @apply absolute left-6 w-2 h-2 bg-blue-500 rounded-full;
        animation: dataflow 2s infinite;
      }

      /* ── Scroll-reveal animation ── */
      .pipeline-section {
        opacity: 0;
        transform: translateY(24px);
        transition: opacity 0.7s ease, transform 0.7s ease;
      }

      .pipeline-section-visible {
        opacity: 1;
        transform: translateY(0);
      }
    </style>
  </body>
</html>