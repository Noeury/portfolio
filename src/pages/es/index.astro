---
import PipelineLayout from "@/layouts/PipelineLayout.astro";
import { changeLanguage, t } from "i18next";

// Import pipeline stage components
import IngestionStage from "@/components/pipeline/IngestionStage.astro";
import ValidationStage from "@/components/pipeline/ValidationStage.astro";
import TransformationStage from "@/components/pipeline/TransformationStage.astro";
import StorageStage from "@/components/pipeline/StorageStage.astro";
import OrchestrationStage from "@/components/pipeline/OrchestrationStage.astro";
import MonitoringStage from "@/components/pipeline/MonitoringStage.astro";
import DeliveryStage from "@/components/pipeline/DeliveryStage.astro";

changeLanguage("es");
---

<PipelineLayout title={t("title")} description={t("description")}>
  <main class="pipeline-main">
    <!-- Pipeline loading animation for initial page load -->
    <div class="pipeline-loader fixed inset-0 z-50 bg-white dark:bg-gray-950 flex flex-col items-center justify-center" id="pipelineLoader" aria-hidden="true">
      <div class="loader-text text-2xl font-bold mb-6 text-blue-600 dark:text-blue-400">
        Cargando Pipeline de Datos...
      </div>
      <div class="loader-bar w-64 h-2 bg-gray-200 dark:bg-gray-800 rounded-full overflow-hidden">
        <div class="loader-progress h-full bg-gradient-to-r from-blue-500 to-purple-600" style="width: 0%"></div>
      </div>
    </div>
    
    <!-- Pipeline stages -->
    <IngestionStage />
    <ValidationStage />
    <TransformationStage />
    <StorageStage />
    <OrchestrationStage />
    <MonitoringStage />
    <DeliveryStage />
  </main>
</PipelineLayout>

<script>
  function setupLoader() {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const loader = document.getElementById('pipelineLoader');
    if (!loader) return;

    if (prefersReducedMotion) {
      loader.style.display = 'none';
      return;
    }

    const progress = loader.querySelector('.loader-progress') as HTMLElement | null;
    if (!progress) return;

    let width = 0;
    const interval = setInterval(() => {
      width += 10;
      progress.style.width = width + '%';
      if (width >= 100) {
        clearInterval(interval);
        loader.style.transition = 'opacity 0.3s ease';
        loader.style.opacity = '0';
        setTimeout(() => { loader.style.display = 'none'; }, 300);
      }
    }, 50);
  }

  function setupScrollObserver() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('pipeline-section-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll('.pipeline-section').forEach(section => {
      observer.observe(section);
    });
  }

  document.addEventListener('astro:page-load', () => {
    setupLoader();
    setupScrollObserver();
  });
</script>

<style>
  .pipeline-main {
    position: relative;
  }

  .pipeline-loader {
    transition: opacity 0.3s ease;
  }

  .loader-progress {
    transition: width 0.05s linear;
  }
</style>
