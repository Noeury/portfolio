---
import SunIcon from "./icons/Sun.astro";
import MoonIcon from "./icons/Moon.astro";
import SystemIcon from "./icons/System.astro";
---

<theme-toggle class="inline-flex items-center gap-1 p-1 rounded-full bg-gray-100 dark:bg-gray-800/80 border border-gray-200/80 dark:border-gray-700/60 shadow-inner">
  <button
    data-theme-btn="light"
    aria-label="Light theme"
    class="relative p-1.5 rounded-full text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-200 transition-colors duration-200 z-10"
  >
    <SunIcon class="size-4" aria-hidden="true" />
  </button>
  
  <button
    data-theme-btn="system"
    aria-label="System theme"
    class="relative p-1.5 rounded-full text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-200 transition-colors duration-200 z-10"
  >
    <SystemIcon class="size-4" aria-hidden="true" />
  </button>
  
  <button
    data-theme-btn="dark"
    aria-label="Dark theme"
    class="relative p-1.5 rounded-full text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-200 transition-colors duration-200 z-10"
  >
    <MoonIcon class="size-4" aria-hidden="true" />
  </button>
</theme-toggle>

<script>
  const sysDark = window.matchMedia("(prefers-color-scheme: dark)");

  function getTheme(): string {
    return localStorage.getItem("theme") ?? "dark";
  }

  function applyTheme(theme: string) {
    const isDark = theme === "dark" || (theme === "system" && sysDark.matches);
    document.documentElement.classList.toggle("dark", isDark);

    // Update ALL theme widgets
    document.querySelectorAll("theme-toggle").forEach(widget => {
      widget.querySelectorAll("button").forEach(btn => {
        const isActive = btn.dataset.themeBtn === theme;
        if (isActive) {
          btn.classList.add("bg-white", "dark:bg-gray-700", "shadow-sm", "text-blue-600", "dark:text-blue-400");
          btn.classList.remove("text-gray-500", "dark:text-gray-400");
        } else {
          btn.classList.remove("bg-white", "dark:bg-gray-700", "shadow-sm", "text-blue-600", "dark:text-blue-400");
          btn.classList.add("text-gray-500", "dark:text-gray-400");
        }
      });
    });
  }

  class ThemeToggle extends HTMLElement {
    constructor() {
      super();
      this.querySelectorAll("button").forEach(btn => {
        btn.addEventListener("click", () => {
          const t = btn.dataset.themeBtn!;
          localStorage.setItem("theme", t);
          applyTheme(t);
        });
      });
      applyTheme(getTheme());
    }
  }

  customElements.define("theme-toggle", ThemeToggle);

  sysDark.addEventListener("change", () => {
    if (getTheme() === "system") applyTheme("system");
  });
</script>
