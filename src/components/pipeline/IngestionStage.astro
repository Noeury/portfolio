---
import SocialPill from "../SocialPill.astro";
import LinkedInIcon from "../icons/LinkedIn.astro";
import MailIcon from "../icons/Mail.astro";
import { Trans } from "astro-i18next/components";
import { t } from "i18next";

const personalImageAlt = "Noeury Feliz";
---

<section id="ingestion" class="pipeline-section min-h-screen flex flex-col justify-center">
  <div class="container mx-auto">
    <div class="mb-12">
      <span class="pipeline-badge bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200 text-xs font-medium px-2.5 py-0.5 rounded">
        01 <Trans i18nKey="pipeline.stages.ingestion">Ingestion</Trans>
      </span>
      <h1 class="pipeline-section-title mt-2">
        <span class="pipeline-icon-wrapper inline-flex items-center justify-center mr-3 bg-blue-100 dark:bg-blue-900 p-3 rounded-full size-12">
          <span class="text-2xl">📥</span>
        </span>
        <Trans i18nKey="pipeline.sections.ingestion.title">Data Ingestion</Trans>
      </h1>
      <p class="text-lg text-gray-600 dark:text-gray-300 mb-6">
        <Trans i18nKey="pipeline.sections.ingestion.subtitle">Introduction</Trans>
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div class="pipeline-content">
        <h2 class="text-4xl font-bold tracking-tight text-gray-800 sm:text-5xl dark:text-white mb-6">
          <Trans i18nKey="pipeline.sections.ingestion.tagline">
            Welcome to my data engineering journey!
          </Trans>
        </h2>
        
        <div class="relative">
          <!-- Animated data points flowing into the text -->
          <div class="data-flow-animation absolute -left-6 top-0 bottom-0 w-4">
            <div class="data-point bg-blue-500 w-2 h-2 rounded-full absolute"></div>
            <div class="data-point bg-blue-500 w-2 h-2 rounded-full absolute" style="animation-delay: 1.2s;"></div>
            <div class="data-point bg-blue-500 w-2 h-2 rounded-full absolute" style="animation-delay: 2.4s;"></div>
          </div>
          
          <p class="mt-6 text-xl text-gray-800 dark:[&>strong]:text-blue-400 [&>strong]:text-blue-700 [&>strong]:font-semibold dark:text-gray-300">
            <Trans i18nKey="hero.paragraph1">
              +5 years of experience. <strong>Systems Engineer, mathematics teacher, and former English teacher</strong> from Barahona, Dominican Republic. Currently dedicated to web application development.
            </Trans>
          </p>
          
          <p class="mt-4 text-gray-600 dark:text-gray-400">
            <Trans i18nKey="pipeline.sections.ingestion.description">
              Just as data ingestion is the first step in a pipeline, here's where you meet me.
            </Trans>
          </p>
        </div>

        <div class="mt-8 flex flex-wrap gap-4">
          <a href="#validation" class="inline-flex items-center px-5 py-3 text-sm font-medium text-center text-white bg-blue-600 rounded-lg hover:bg-blue-700 focus:outline-none">
            <Trans i18nKey="pipeline.sections.ingestion.cta">Scroll to explore my pipeline</Trans>
            <svg class="w-3.5 h-3.5 ml-2" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 10">
                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 5h12m0 0L9 1m4 4L9 9"/>
            </svg>
          </a>
        </div>
        
        <nav class="flex flex-wrap gap-4 mt-8">
          <SocialPill href="mailto:noeuryfeliz@gmail.com">
            <MailIcon class="size-4" />
            <Trans i18nKey="header.contactme.title"> Contáctame </Trans>
          </SocialPill>
          <SocialPill
            href="https://www.linkedin.com/in/noeury-nizael-feliz-feliz-32506ab7/"
          >
            <LinkedInIcon class="size-4" />
            LinkedIn
          </SocialPill>
        </nav>
      </div>
      
      <div class="relative">
        <!-- Profile image with data pipeline nodes overlay -->
        <div class="absolute inset-0 flex items-center justify-center">
          <div class="w-64 h-64 rounded-full border-4 border-dashed border-blue-200 dark:border-blue-800 animate-spin-slow opacity-30"></div>
        </div>
        
        <div class="flex justify-center">
          <div class="relative">
            <div class="absolute -inset-1 bg-gradient-to-r from-blue-600 to-indigo-600 rounded-full blur opacity-30 group-hover:opacity-100 transition duration-1000 group-hover:duration-200"></div>
            <img
              class="relative rounded-full shadow-2xl size-64 object-cover border-4 border-white dark:border-gray-800"
              src="/Me.jpg"
              alt={personalImageAlt}
              width="256"
              height="256"
              fetchpriority="high"
              decoding="async"
            />
            
            <!-- Data points flowing around the image -->
            <div class="data-point absolute w-3 h-3 rounded-full bg-blue-500 top-4 right-0 animate-pulse"></div>
            <div class="data-point absolute w-2 h-2 rounded-full bg-indigo-500 bottom-4 right-8 animate-pulse" style="animation-delay: 0.5s;"></div>
            <div class="data-point absolute w-4 h-4 rounded-full bg-sky-500 top-12 left-0 animate-pulse" style="animation-delay: 1s;"></div>
          </div>
        </div>
        
        <div class="mt-6 flex justify-center">
          <a
            href="#validation"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center transition hover:scale-105 bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200 px-4 py-2 rounded-full text-sm font-medium"
          >
            <span class="mr-2 text-xl">⏬</span> <span class="mr-1"><Trans i18nKey="pipeline.nextStagePrefix">Next Stage:</Trans></span> <Trans i18nKey="pipeline.stages.validation">Validation</Trans>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @reference "../../styles/global.css";
  .animate-spin-slow {
    animation: spin 8s linear infinite;
  }
  
  @keyframes spin {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }
  
  .data-point {
    animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
  
  @keyframes pulse {
    0%, 100% {
      opacity: 0.5;
      transform: scale(1);
    }
    50% {
      opacity: 1;
      transform: scale(1.2);
    }
  }
  
  .data-flow-animation {
    position: relative;
  }
  
  .data-flow-animation .data-point {
    animation: dataFlowVertical 3s infinite linear;
  }
  
  @keyframes dataFlowVertical {
    0% {
      top: -10px;
      opacity: 0;
    }
    50% {
      opacity: 1;
    }
    100% {
      top: 100%;
      opacity: 0;
    }
  }
  
  .pipeline-badge {
    @apply inline-flex items-center;
  }
</style>