---
import { Trans } from "astro-i18next/components";
import { t } from "i18next";
import SocialPill from "../SocialPill.astro";
import GitHub from "../icons/GitHub.astro";
import LinkedInIcon from "../icons/LinkedIn.astro";
import MailIcon from "../icons/Mail.astro";

// Social media links
const socialLinks = [
  {
    name: "Email",
    url: "mailto:noeuryfeliz@gmail.com",
    icon: MailIcon,
    label: "noeuryfeliz@gmail.com"
  },
  {
    name: "LinkedIn",
    url: "https://www.linkedin.com/in/noeury-nizael-feliz-feliz-32506ab7/",
    icon: LinkedInIcon,
    label: "LinkedIn Profile"
  },
  {
    name: "GitHub",
    url: "https://github.com/Noeury",
    icon: GitHub,
    label: "GitHub Profile"
  }
];
---

<section id="delivery" class="pipeline-section min-h-screen py-24">
  <div class="container mx-auto">
    <div class="mb-12">
      <span class="pipeline-badge bg-red-100 dark:bg-red-900 text-red-800 dark:text-red-200 text-xs font-medium px-2.5 py-0.5 rounded">
        07 <Trans i18nKey="pipeline.stages.delivery">Delivery</Trans>
      </span>
      <h2 class="pipeline-section-title mt-2">
        <span class="pipeline-icon-wrapper inline-block mr-3 bg-red-100 dark:bg-red-900 p-3 rounded-full w-12 h-12 flex items-center justify-center">
          <span class="text-2xl">🚀</span>
        </span>
        <Trans i18nKey="pipeline.sections.delivery.title">Data Delivery</Trans>
      </h2>
      <p class="text-lg text-gray-600 dark:text-gray-300 mb-6">
        <Trans i18nKey="pipeline.sections.delivery.subtitle">Contact & Connect</Trans>
      </p>
      <p class="text-gray-600 dark:text-gray-400 max-w-3xl">
        <Trans i18nKey="pipeline.sections.delivery.description">
          Like delivering processed data to users, I'm ready to connect and discuss opportunities.
        </Trans>
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
      <!-- Contact Form -->
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg p-8 border border-gray-200 dark:border-gray-700">
        <h3 class="text-xl font-bold mb-6 text-red-700 dark:text-red-400 flex items-center">
          <span class="mr-2">📨</span>
          <Trans i18nKey="pipeline.sections.delivery.contact_form">Contact Form</Trans>
        </h3>
        
        <!-- Data packets animation -->
        <div class="data-packets-container absolute inset-0 pointer-events-none overflow-hidden">
          <div class="data-packet"></div>
          <div class="data-packet" style="animation-delay: 1s;"></div>
          <div class="data-packet" style="animation-delay: 2s;"></div>
        </div>
        
        <form class="contact-form space-y-6 relative z-10" id="contactForm">
          <div class="form-group">
            <label for="name" class="block mb-2 text-sm font-medium text-gray-900 dark:text-gray-300">
              Name
            </label>
            <input 
              type="text" 
              id="name" 
              class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-red-500 focus:border-red-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-red-500 dark:focus:border-red-500" 
              placeholder="Your name" 
              required
            />
          </div>
          
          <div class="form-group">
            <label for="email" class="block mb-2 text-sm font-medium text-gray-900 dark:text-gray-300">
              Email
            </label>
            <input 
              type="email" 
              id="email" 
              class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-red-500 focus:border-red-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-red-500 dark:focus:border-red-500" 
              placeholder="your.email@example.com" 
              required
            />
          </div>
          
          <div class="form-group">
            <label for="subject" class="block mb-2 text-sm font-medium text-gray-900 dark:text-gray-300">
              Subject
            </label>
            <input 
              type="text" 
              id="subject" 
              class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-red-500 focus:border-red-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-red-500 dark:focus:border-red-500" 
              placeholder="What's this about?" 
              required
            />
          </div>
          
          <div class="form-group">
            <label for="message" class="block mb-2 text-sm font-medium text-gray-900 dark:text-gray-300">
              Message
            </label>
            <textarea 
              id="message" 
              rows="4" 
              class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-red-500 focus:border-red-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-red-500 dark:focus:border-red-500" 
              placeholder="Your message..."
              required
            ></textarea>
          </div>
          
          <button 
            type="submit" 
            class="delivery-button w-full text-white bg-gradient-to-r from-red-500 to-red-700 hover:bg-gradient-to-br focus:ring-4 focus:outline-none focus:ring-red-300 dark:focus:ring-red-800 font-medium rounded-lg text-sm px-5 py-3 text-center mb-2"
          >
            <span class="relative z-10 flex items-center justify-center">
              <span class="mr-2">🚀</span>
              <Trans i18nKey="pipeline.sections.delivery.message">Send Message</Trans>
            </span>
          </button>
        </form>
      </div>
      
      <!-- Connect & Social Links -->
      <div class="space-y-8">
        <!-- Final Pipeline Output -->
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg p-8 border border-gray-200 dark:border-gray-700">
          <h3 class="text-xl font-bold mb-6 text-red-700 dark:text-red-400 flex items-center">
            <span class="mr-2">🔄</span>
            Pipeline Completed
          </h3>
          
          <div class="pipeline-completed relative overflow-hidden rounded-lg bg-gradient-to-r from-blue-500 via-purple-500 to-red-500 p-8 text-white">
            <!-- Data flow animation in background -->
            <div class="absolute inset-0 opacity-20">
              <div class="data-flow"></div>
            </div>
            
            <div class="relative z-10">
              <h4 class="text-2xl font-bold mb-4">
                <Trans i18nKey="pipeline.sections.delivery.cta">Let's Connect</Trans>
              </h4>
              <p class="mb-6">Thank you for exploring my portfolio pipeline! I'm currently available for new opportunities and would love to discuss how we can work together.</p>
              
              <!-- Call to action button -->
              <a 
                href="mailto:noeuryfeliz@gmail.com" 
                class="inline-flex items-center px-5 py-3 text-sm font-medium text-center text-red-600 bg-white rounded-lg hover:bg-gray-100 focus:ring-4 focus:outline-none focus:ring-gray-200"
              >
                <span class="mr-2">📧</span>
                Email Me Directly
                <svg class="w-3.5 h-3.5 ml-2" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 10">
                  <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 5h12m0 0L9 1m4 4L9 9"/>
                </svg>
              </a>
            </div>
          </div>
        </div>
        
        <!-- Social Links -->
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg p-8 border border-gray-200 dark:border-gray-700">
          <h3 class="text-xl font-bold mb-6 text-red-700 dark:text-red-400 flex items-center">
            <span class="mr-2">🔗</span>
            Connect With Me
          </h3>
          
          <div class="social-links space-y-4">
            {socialLinks.map((social) => (
              <a 
                href={social.url} 
                class="social-link flex items-center p-4 rounded-lg bg-gray-50 dark:bg-gray-700 hover:bg-gray-100 dark:hover:bg-gray-600 transition-all"
                target="_blank"
                rel="noopener noreferrer"
              >
                <div class="link-icon w-10 h-10 rounded-full bg-red-100 dark:bg-red-900 flex items-center justify-center mr-4">
                  <social.icon class="size-5 text-red-600 dark:text-red-400" />
                </div>
                <div>
                  <h4 class="font-medium">{social.name}</h4>
                  <p class="text-sm text-gray-500 dark:text-gray-400">{social.label}</p>
                </div>
                <div class="ml-auto">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                  </svg>
                </div>
              </a>
            ))}
          </div>
        </div>
        
        <!-- Available for Hire Banner -->
        <div class="hire-banner bg-gradient-to-r from-blue-600 to-blue-800 text-white rounded-lg p-6 flex items-center">
          <div class="hire-status w-4 h-4 rounded-full bg-green-400 animate-pulse mr-4"></div>
          <div>
            <h4 class="font-bold">Available for New Opportunities</h4>
            <p class="text-sm text-blue-100">Open to freelance, contracts, and full-time positions</p>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Final Pipeline Navigation - Back to top -->
    <div class="mt-16 flex justify-center">
      <a
        href="#ingestion"
        class="pipeline-reset inline-flex items-center px-5 py-3 text-sm font-medium text-center text-white bg-gradient-to-r from-blue-600 to-red-600 rounded-lg hover:bg-gradient-to-br focus:ring-4 focus:outline-none focus:ring-blue-300 dark:focus:ring-blue-800 transition-transform hover:-translate-y-1"
      >
        <span class="mr-2">🔄</span>
        Restart Pipeline
      </a>
    </div>
  </div>
</section>

<style>
  /* Form animations */
  .contact-form .form-group {
    transition: all 0.3s ease;
  }
  
  .contact-form .form-group:focus-within {
    transform: translateY(-5px);
  }
  
  /* Button animation */
  .delivery-button {
    position: relative;
    overflow: hidden;
    z-index: 1;
  }
  
  .delivery-button::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to right, transparent, rgba(255, 255, 255, 0.2), transparent);
    transform: translateX(-100%);
    transition: 0.5s;
    z-index: 0;
  }
  
  .delivery-button:hover::after {
    transform: translateX(100%);
  }
  
  /* Data packets animation */
  .data-packets-container {
    z-index: 0;
    opacity: 0.1;
  }
  
  .data-packet {
    position: absolute;
    width: 10px;
    height: 10px;
    background-color: #ef4444;
    border-radius: 50%;
    top: 50%;
    left: 0;
    animation: data-packet-move 4s linear infinite;
  }
  
  @keyframes data-packet-move {
    0% {
      left: 0;
      top: 10%;
      opacity: 0;
    }
    20% {
      opacity: 1;
    }
    80% {
      opacity: 1;
    }
    100% {
      left: 100%;
      top: 90%;
      opacity: 0;
    }
  }
  
  /* Data flow animation */
  .data-flow {
    background-image: linear-gradient(
      to bottom right,
      transparent 20%,
      rgba(255, 255, 255, 0.3) 40%,
      transparent 60%
    );
    background-size: 300% 300%;
    animation: data-flow-animation 3s linear infinite;
    position: absolute;
    inset: 0;
  }
  
  @keyframes data-flow-animation {
    0% {
      background-position: 0% 0%;
    }
    100% {
      background-position: 100% 100%;
    }
  }
  
  /* Social link animations */
  .social-link {
    transition: all 0.3s ease;
  }
  
  .social-link:hover {
    transform: translateX(10px);
  }
  
  /* Pipeline reset button */
  .pipeline-reset {
    position: relative;
    overflow: hidden;
  }
  
  .pipeline-reset::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.2),
      transparent
    );
    transition: 0.5s;
  }
  
  .pipeline-reset:hover::before {
    left: 100%;
  }
  
  /* Hire status animation */
  .hire-status {
    box-shadow: 0 0 0 rgba(74, 222, 128, 0.4);
    animation: pulse 2s infinite;
  }
  
  @keyframes pulse {
    0% {
      box-shadow: 0 0 0 0 rgba(74, 222, 128, 0.4);
    }
    70% {
      box-shadow: 0 0 0 10px rgba(74, 222, 128, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(74, 222, 128, 0);
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const contactForm = document.getElementById('contactForm');
    const submitButton = contactForm.querySelector('button[type="submit"]');
    const originalButtonText = submitButton.innerHTML;
    
    contactForm.addEventListener('submit', async function(e) {
      e.preventDefault();
      
      // Get form data
      const formData = new FormData(contactForm);
      const name = document.getElementById('name').value;
      const email = document.getElementById('email').value;
      const subject = document.getElementById('subject').value;
      const message = document.getElementById('message').value;
      
      // Validate form
      if (!name || !email || !subject || !message) {
        showNotification('Please fill in all fields', 'error');
        return;
      }
      
      // Update button state
      submitButton.disabled = true;
      submitButton.innerHTML = `
        <span class="relative z-10 flex items-center justify-center">
          <svg class="animate-spin -ml-1 mr-3 h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          Sending...
        </span>
      `;
      
      try {
        // Create mailto link with form data
        const mailtoLink = `mailto:noeuryfeliz@gmail.com?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(
          `Name: ${name}\nEmail: ${email}\n\nMessage:\n${message}`
        )}`;
        
        // Open email client
        window.location.href = mailtoLink;
        
        // Show success message
        showNotification('Email client opened! Please send the email to complete your message.', 'success');
        
        // Reset form after a delay
        setTimeout(() => {
          contactForm.reset();
        }, 1000);
        
      } catch (error) {
        console.error('Error:', error);
        showNotification('Something went wrong. Please try again or email directly.', 'error');
      } finally {
        // Reset button state
        setTimeout(() => {
          submitButton.disabled = false;
          submitButton.innerHTML = originalButtonText;
        }, 2000);
      }
    });
    
    // Notification function
    function showNotification(message, type) {
      // Remove existing notifications
      const existingNotifications = document.querySelectorAll('.contact-notification');
      existingNotifications.forEach(notification => notification.remove());
      
      // Create notification
      const notification = document.createElement('div');
      notification.className = `contact-notification fixed top-4 right-4 z-50 p-4 rounded-lg shadow-lg max-w-sm transition-all duration-300 transform translate-x-full`;
      
      if (type === 'success') {
        notification.className += ' bg-green-500 text-white';
      } else {
        notification.className += ' bg-red-500 text-white';
      }
      
      notification.innerHTML = `
        <div class="flex items-center">
          <span class="mr-2">${type === 'success' ? '✅' : '❌'}</span>
          <span>${message}</span>
          <button class="ml-4 text-white hover:text-gray-200" onclick="this.parentElement.parentElement.remove()">
            ✕
          </button>
        </div>
      `;
      
      document.body.appendChild(notification);
      
      // Animate in
      setTimeout(() => {
        notification.classList.remove('translate-x-full');
      }, 100);
      
      // Auto remove after 5 seconds
      setTimeout(() => {
        if (notification.parentElement) {
          notification.classList.add('translate-x-full');
          setTimeout(() => {
            if (notification.parentElement) {
              notification.remove();
            }
          }, 300);
        }
      }, 5000);
    }
  });
</script>