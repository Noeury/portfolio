---
import { Trans } from "astro-i18next/components";
import { t } from "i18next";

// Leadership and orchestration experience data
const leadershipExperience = [
  {
    title: "Backend Team Leader & SCRUM Master",
    company: "UCATEBA",
    period: "September 2023 - Present",
    description: "Led backend development team, implemented agile methodologies, and coordinated software implementations and database solutions.",
    achievements: [
      "Improved team productivity by 30% through agile workflow optimizations",
      "Successfully coordinated cross-functional teams for complex integration projects",
      "Mentored junior developers and facilitated knowledge sharing sessions"
    ]
  }
];

// Orchestration tools and methodologies
const orchestrationTools = [
  { name: "Agile/Scrum", icon: "🔄" },
  { name: "Jira", icon: "📊" },
  { name: "Git/GitHub", icon: "🔀" },
  { name: "CI/CD Pipelines", icon: "⚙️" },
];

// Work methodologies
const workMethodologies = [
  {
    name: "Agile Development",
    description: "Implementation of Scrum and Kanban practices for iterative development and continuous improvement.",
    icon: "🔄"
  },
  {
    name: "DevOps Integration",
    description: "Streamlining development and operations through automated pipelines and continuous deployment.",
    icon: "🔧"
  },
  {
    name: "Cross-functional Collaboration",
    description: "Breaking down silos between teams to enable seamless communication and workflow integration.",
    icon: "🤝"
  }
];
---

<section id="orchestration" class="pipeline-section min-h-screen py-24">
  <div class="container mx-auto">
    <div class="mb-12">
      <span class="pipeline-badge bg-purple-100 dark:bg-purple-900 text-purple-800 dark:text-purple-200 text-xs font-medium px-2.5 py-0.5 rounded">
        05 <Trans i18nKey="pipeline.stages.orchestration">Orchestration</Trans>
      </span>
      <h2 class="pipeline-section-title mt-2">
        <span class="pipeline-icon-wrapper inline-block mr-3 bg-purple-100 dark:bg-purple-900 p-3 rounded-full w-12 h-12 flex items-center justify-center">
          <span class="text-2xl">🔄</span>
        </span>
        <Trans i18nKey="pipeline.sections.orchestration.title">Data Orchestration</Trans>
      </h2>
      <p class="text-lg text-gray-600 dark:text-gray-300 mb-6">
        <Trans i18nKey="pipeline.sections.orchestration.subtitle">Workflow & Leadership</Trans>
      </p>
      <p class="text-gray-600 dark:text-gray-400 max-w-3xl">
        <Trans i18nKey="pipeline.sections.orchestration.description">
          Similar to orchestrating complex pipelines, I've coordinated teams and workflows.
        </Trans>
      </p>
    </div>

    <!-- Orchestration Workflow Diagram -->
    <div class="mb-16 bg-white dark:bg-gray-800 rounded-lg shadow-lg p-6 overflow-hidden">
      <h3 class="text-xl font-bold mb-6 text-purple-700 dark:text-purple-400">Workflow Orchestration</h3>
      
      <div class="relative workflow-diagram">
        <!-- Animated background grid -->
        <div class="absolute inset-0 workflow-grid"></div>
        
        <!-- Workflow nodes and connections -->
        <div class="relative z-10 orchestration-flow flex flex-col md:flex-row justify-around items-center py-10 px-4">
          <div class="workflow-node planning mb-8 md:mb-0">
            <div class="node-icon">📋</div>
            <div class="node-label">Planning</div>
          </div>
          
          <div class="workflow-arrow hidden md:block">
            <svg width="60" height="20" viewBox="0 0 60 20">
              <path d="M0 10 L50 10 L40 5 M50 10 L40 15" stroke="currentColor" fill="none" stroke-width="2" />
            </svg>
          </div>
          
          <div class="workflow-node development mb-8 md:mb-0">
            <div class="node-icon">💻</div>
            <div class="node-label">Development</div>
          </div>
          
          <div class="workflow-arrow hidden md:block">
            <svg width="60" height="20" viewBox="0 0 60 20">
              <path d="M0 10 L50 10 L40 5 M50 10 L40 15" stroke="currentColor" fill="none" stroke-width="2" />
            </svg>
          </div>
          
          <div class="workflow-node testing mb-8 md:mb-0">
            <div class="node-icon">🧪</div>
            <div class="node-label">Testing</div>
          </div>
          
          <div class="workflow-arrow hidden md:block">
            <svg width="60" height="20" viewBox="0 0 60 20">
              <path d="M0 10 L50 10 L40 5 M50 10 L40 15" stroke="currentColor" fill="none" stroke-width="2" />
            </svg>
          </div>
          
          <div class="workflow-node deployment">
            <div class="node-icon">🚀</div>
            <div class="node-label">Deployment</div>
          </div>
        </div>
        
        <!-- Circular arrow back to planning -->
        <div class="hidden md:block relative z-10">
          <svg class="mx-auto" width="600" height="40" viewBox="0 0 600 40">
            <path d="M550 10 C600 10, 600 30, 550 30 C500 30, 150 30, 100 30 C50 30, 50 10, 100 10" stroke="currentColor" fill="none" stroke-width="2" stroke-dasharray="5,5" />
            <path d="M110 5 L100 10 L110 15" stroke="currentColor" fill="none" stroke-width="2" />
          </svg>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-16">
      <!-- Team Leadership Experience -->
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg p-6">
        <h3 class="text-xl font-bold mb-6 text-purple-700 dark:text-purple-400 flex items-center">
          <span class="mr-2">👥</span>
          <Trans i18nKey="pipeline.sections.orchestration.team_leadership">Team Leadership</Trans>
        </h3>
        
        {leadershipExperience.map((experience) => (
          <div class="leadership-card mb-6 border-l-4 border-purple-500 pl-4">
            <div class="flex justify-between items-start">
              <h4 class="font-bold text-lg">{experience.title}</h4>
              <span class="text-sm text-gray-500 dark:text-gray-400">{experience.period}</span>
            </div>
            <p class="text-sm text-purple-700 dark:text-purple-400 mb-2">{experience.company}</p>
            <p class="text-gray-600 dark:text-gray-300 mb-3">{experience.description}</p>
            
            <h5 class="font-semibold text-sm mb-2">Key Achievements:</h5>
            <ul class="list-disc pl-5 space-y-1 text-sm text-gray-600 dark:text-gray-300">
              {experience.achievements.map((achievement) => (
                <li>{achievement}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
      
      <!-- Orchestration Tools & Methodologies -->
      <div>
        <!-- Tools -->
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg p-6 mb-8">
          <h3 class="text-xl font-bold mb-6 text-purple-700 dark:text-purple-400 flex items-center">
            <span class="mr-2">🛠️</span>
            <Trans i18nKey="pipeline.sections.orchestration.tools">Orchestration Tools</Trans>
          </h3>
          
          <div class="grid grid-cols-2 gap-4">
            {orchestrationTools.map((tool) => (
              <div class="group flex flex-col items-center p-4 rounded-lg bg-gray-50 dark:bg-gray-700/50 hover:bg-gradient-to-br hover:from-purple-50 hover:to-blue-50 dark:hover:from-purple-900/20 dark:hover:to-blue-900/20 transition-all duration-300 hover:scale-105 hover:shadow-lg">
                <div class="mb-3 p-3 rounded-full bg-white dark:bg-gray-800 shadow-md group-hover:shadow-lg transition-shadow duration-300">
                  <span class="text-2xl transition-transform duration-300 group-hover:scale-110">{tool.icon}</span>
                </div>
                <span class="font-medium text-sm text-center text-gray-700 dark:text-gray-300 group-hover:text-gray-900 dark:group-hover:text-white transition-colors duration-300">{tool.name}</span>
              </div>
            ))}
          </div>
        </div>
        
        <!-- Work Methodologies -->
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg p-6">
          <h3 class="text-xl font-bold mb-6 text-purple-700 dark:text-purple-400 flex items-center">
            <span class="mr-2">📊</span>
            <Trans i18nKey="pipeline.sections.orchestration.workflow">Work Methodologies</Trans>
          </h3>
          
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            {workMethodologies.map((methodology) => (
              <div class="methodology-card bg-gray-50 dark:bg-gray-700 p-4 rounded-lg text-center">
                <div class="text-3xl mb-2">{methodology.icon}</div>
                <h4 class="font-bold text-sm mb-2">{methodology.name}</h4>
                <p class="text-xs text-gray-600 dark:text-gray-300">{methodology.description}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Navigation to next stage -->
    <div class="mt-16 flex justify-center">
      <a
        href="#monitoring"
        class="pipeline-next-stage inline-flex items-center px-5 py-3 text-sm font-medium text-center text-white bg-blue-600 rounded-lg hover:bg-blue-700 focus:outline-none transition-transform hover:translate-y-1"
      >
        <span class="mr-2">Next Stage:</span> Monitoring
        <svg class="w-3.5 h-3.5 ml-2" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 10">
          <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 5h12m0 0L9 1m4 4L9 9"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .workflow-grid {
    background-image: 
      linear-gradient(rgba(139, 92, 246, 0.1) 1px, transparent 1px),
      linear-gradient(90deg, rgba(139, 92, 246, 0.1) 1px, transparent 1px);
    background-size: 20px 20px;
    z-index: 0;
  }
  
  .workflow-node {
    @apply relative flex flex-col items-center justify-center w-24 h-24 rounded-lg bg-white dark:bg-gray-800 shadow-md border border-purple-200 dark:border-purple-900 z-10 transition-all duration-300;
  }
  
  .workflow-node:hover {
    @apply shadow-lg transform -translate-y-1 border-purple-400 dark:border-purple-500;
  }
  
  .workflow-node .node-icon {
    @apply text-3xl mb-2;
  }
  
  .workflow-node .node-label {
    @apply text-xs font-semibold text-center;
  }
  
  .workflow-arrow {
    @apply text-purple-500 dark:text-purple-400;
  }
  
  /* Add animated data flow along the arrows */
  .orchestration-flow {
    position: relative;
  }
  
  .orchestration-flow::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(139, 92, 246, 0.3) 50%,
      transparent 100%
    );
    background-size: 200% 100%;
    animation: dataFlowHorizontal 3s linear infinite;
    pointer-events: none;
    z-index: 1;
    opacity: 0.3;
  }
  
  @keyframes dataFlowHorizontal {
    0% {
      background-position: 100% 0;
    }
    100% {
      background-position: -100% 0;
    }
  }
  
  .leadership-card {
    position: relative;
    overflow: hidden;
  }
  
  .leadership-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: -4px;
    width: 4px;
    height: 100%;
    background: linear-gradient(to bottom, rgba(139, 92, 246, 0.5), rgba(59, 130, 246, 0.5));
    z-index: 1;
  }
  
  .methodology-card {
    transition: all 0.3s ease;
  }
  
  .methodology-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
  }
  
  .pipeline-next-stage {
    position: relative;
    overflow: hidden;
  }
  
  .pipeline-next-stage::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.2),
      transparent
    );
    transition: 0.5s;
  }
  
  .pipeline-next-stage:hover::before {
    left: 100%;
  }
</style>