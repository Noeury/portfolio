---
import { Trans } from "astro-i18next/components";
import { t } from "i18next";

const stages = [
  {
    id: "ingestion",
    name: t("pipeline.stages.ingestion"),
    icon: "📥",
    description: t("pipeline.descriptions.ingestion")
  },
  {
    id: "validation",
    name: t("pipeline.stages.validation"),
    icon: "✓",
    description: t("pipeline.descriptions.validation")
  },
  {
    id: "transformation",
    name: t("pipeline.stages.transformation"),
    icon: "🔄",
    description: t("pipeline.descriptions.transformation")
  },
  {
    id: "storage",
    name: t("pipeline.stages.storage"),
    icon: "💾",
    description: t("pipeline.descriptions.storage")
  },
  {
    id: "orchestration",
    name: t("pipeline.stages.orchestration"),
    icon: "🔄",
    description: t("pipeline.descriptions.orchestration")
  },
  {
    id: "monitoring",
    name: t("pipeline.stages.monitoring"),
    icon: "📊",
    description: t("pipeline.descriptions.monitoring")
  },
  {
    id: "delivery",
    name: t("pipeline.stages.delivery"),
    icon: "🚀",
    description: t("pipeline.descriptions.delivery")
  },
];
---

<div class="fixed left-0 top-1/2 -translate-y-1/2 z-20 hidden md:block pipeline-nav-container">
  <div class="pipeline-progress flex flex-col items-center gap-2 px-2 py-6 bg-white/80 dark:bg-gray-900/80 backdrop-blur-sm rounded-r-lg border-r border-t border-b border-blue-200 dark:border-blue-900 shadow-lg">
    {stages.map((stage, index) => (
      <div>
        <a 
          href={`#${stage.id}`} 
          class="pipeline-stage group flex items-center gap-2 py-2 transition-all duration-300 hover:translate-x-1"
          data-stage={stage.id}
        >
          <div class="pipeline-icon w-8 h-8 rounded-full flex items-center justify-center bg-gray-100 dark:bg-gray-800 border border-blue-200 dark:border-blue-800 group-hover:bg-blue-500 group-hover:text-white transition-colors">
            <span>{stage.icon}</span>
          </div>
          <div class="pipeline-label absolute left-16 opacity-0 group-hover:opacity-100 transition-opacity duration-300 whitespace-nowrap pointer-events-none">
            <span class="font-semibold text-sm">{stage.name}</span>
          </div>
        </a>
        
        {index < stages.length - 1 && 
          <div class="h-6 w-0.5 bg-blue-300 dark:bg-blue-700 mx-auto"></div>
        }
      </div>
    ))}
  </div>
</div>

<script>
  // Function to update active stage based on scroll position
  function updateActiveStage() {
    const sections = document.querySelectorAll('section[id]');
    const scrollPosition = window.scrollY + window.innerHeight / 3;

    sections.forEach(section => {
      const sectionId = section.getAttribute('id');
      if (!sectionId) return;
      
      const rect = section.getBoundingClientRect();
      const sectionTop = rect.top + window.scrollY;
      const sectionHeight = rect.height;
      
      if (scrollPosition >= sectionTop && scrollPosition < sectionTop + sectionHeight) {
        // Remove active class from all stages
        document.querySelectorAll('.pipeline-stage').forEach(item => {
          item.classList.remove('active');
          const icon = item.querySelector('.pipeline-icon');
          if (icon) {
            icon.classList.remove('bg-blue-500', 'text-white');
          }
        });
        
        // Add active class to current stage
        const activeStage = document.querySelector(`.pipeline-stage[data-stage="${sectionId}"]`);
        if (activeStage) {
          activeStage.classList.add('active');
          const activeIcon = activeStage.querySelector('.pipeline-icon');
          if (activeIcon) {
            activeIcon.classList.add('bg-blue-500', 'text-white');
          }
        }
      }
    });
  }

  // Add dataflow animation dots
  function addDataflowDots() {
    const progressBar = document.querySelector('.pipeline-progress');
    if (!progressBar) return;
    
    setInterval(() => {
      const dot = document.createElement('div');
      dot.classList.add('dataflow-dot');
      // Random vertical position
      dot.style.top = `${Math.random() * 100}%`;
      progressBar.appendChild(dot);
      
      // Remove dot after animation completes
      setTimeout(() => {
        dot.remove();
      }, 2000);
    }, 800);
  }

  document.addEventListener('astro:page-load', () => {
    updateActiveStage();
    window.addEventListener('scroll', updateActiveStage);
    addDataflowDots();
  });
</script>

<style>
  .pipeline-stage.active .pipeline-label {
    @apply opacity-100 font-bold text-blue-600 dark:text-blue-400;
  }
  
  /* Pipeline navigation container styling */
  .pipeline-nav-container {
    width: 58px;
    transition: width 0.3s ease;
  }
  
  .pipeline-nav-container:hover {
    width: 180px;
  }
  
  .pipeline-nav-container:hover .pipeline-label {
    left: 60px;
  }
  
  .dataflow-dot {
    @apply absolute left-6 w-2 h-2 bg-blue-500 rounded-full;
    animation: dataflow 2s infinite;
  }
  
  @keyframes dataflow {
    0% {
      transform: translateY(-10px);
      opacity: 0;
    }
    50% {
      opacity: 1;
    }
    100% {
      transform: translateY(10px);
      opacity: 0;
    }
  }
</style>