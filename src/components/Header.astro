---
import { t } from "i18next";
import CustomLanguageSelector from "./CustomLanguageSelector.astro";
import ThemeToggle from "./ThemeToggle.astro";

const navItems = [
  {
    title: t("header.experience.title"),
    label: "experiencia",
    url: "#experiencia",
  },
  {
    title: t("header.projects.title"),
    label: "proyectos",
    url: "#proyectos",
  },
  {
    title: t("header.aboutme.title"),
    label: "sobre-mi",
    url: "#sobre-mi",
  },
  // {
  //   title: t("header.contactme.title"),
  //   label: "contacto",
  //   url: "mailto:noeuryfeliz@gmail.com",
  // },
];
---

<header
  class="fixed top-0 z-10 flex items-center justify-center w-full mx-auto mt-2"
  role="banner"
>
  <div class="md:hidden absolute left-4">
    <button id="menu-toggle" aria-label="Open navigation menu" aria-expanded="false" aria-controls="mobile-menu" class="p-2 text-gray-600 dark:text-gray-200 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <nav
    class="flex items-center gap-2 px-3 text-sm font-medium rounded-full text-gray-600 dark:text-gray-200"
    aria-label="Main navigation"
  >
    <div id="mobile-menu" role="dialog" aria-modal="true" aria-label="Navigation menu" class="fixed inset-0 bg-white dark:bg-gray-900 z-50 flex-col items-center justify-center hidden md:hidden pt-16">
      <button id="close-menu" aria-label="Close navigation menu" class="absolute top-4 right-4 p-2 text-gray-600 dark:text-gray-200 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
      {
        navItems.map((link) => (
          <a
            class="mobile-link block py-3 px-4 text-lg text-center w-full transition hover:text-blue-500 dark:hover:text-blue-400"
            aria-label={link.label}
            href={link.url}
          >
            {link.title}
          </a>
        ))
      }
      <div class="flex items-center justify-center gap-4 mt-6">
        <ThemeToggle />
        <CustomLanguageSelector
          showFlag={true}
          class="bg-transparent text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-18 py-1 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500"
        />
      </div>
    </div>
    
    <div class="hidden md:flex items-center">
      {
        navItems.map((link) => (
          <a
            class="relative block px-2 py-2 transition hover:text-blue-500 dark:hover:text-blue-400 z-[1]"
            aria-label={link.label}
            href={link.url}
          >
            {link.title}
          </a>
        ))
      }
    </div>
    
    <div class="hidden md:flex items-center gap-1">
      <ThemeToggle />
      <CustomLanguageSelector
        showFlag={true}
        class="bg-transparent text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-18 py-1 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500"
      />
    </div>
  </nav>

  <script>
    document.addEventListener("astro:page-load", () => {
      const sections = document.querySelectorAll("section");
      const desktopNavItems = document.querySelectorAll("header nav .md\\:flex a");
      const mobileNavItems = document.querySelectorAll(".mobile-link");
      const menuToggle = document.getElementById("menu-toggle");
      const closeMenu = document.getElementById("close-menu");
      const mobileMenu = document.getElementById("mobile-menu");
  
      // Mobile menu toggle
      if (menuToggle) {
        menuToggle.addEventListener("click", () => {
          mobileMenu?.classList.remove("hidden");
          mobileMenu?.classList.add("flex");
          document.body.classList.add("overflow-hidden");
        });
      }
  
      if (closeMenu) {
        closeMenu.addEventListener("click", () => {
          mobileMenu?.classList.add("hidden");
          mobileMenu?.classList.remove("flex");
          document.body.classList.remove("overflow-hidden");
        });
      }
  
      // Close mobile menu when clicking on links
      mobileNavItems.forEach(link => {
        link.addEventListener("click", () => {
          mobileMenu?.classList.add("hidden");
          mobileMenu?.classList.remove("flex");
          document.body.classList.remove("overflow-hidden");
        });
      });
  
      const callback = (entries: any[]) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            // Update desktop nav
            desktopNavItems.forEach((item) => {
              if (item.getAttribute("aria-label") == entry.target.id) {
                item.classList.add("text-blue-600");
              } else {
                item.classList.remove("text-blue-600");
              }
            });
            
            // Update mobile nav
            mobileNavItems.forEach((item) => {
              if (item.getAttribute("aria-label") == entry.target.id) {
                item.classList.add("text-blue-600");
              } else {
                item.classList.remove("text-blue-600");
              }
            });
          }
        });
      };
  
      const observer = new IntersectionObserver(callback, {
        root: null,
        rootMargin: "0px",
        threshold: 0.3,
      });
  
      sections.forEach((section) => {
        observer.observe(section);
      });
  
      // Cleanup function
      document.onvisibilitychange = () => {
        if (document.visibilityState === "hidden") {
          observer.disconnect();
        } else {
          sections.forEach((section) => {
            observer.observe(section);
          });
        }
      };
    });
  </script>

  <style>
    @reference "../styles/global.css";
    nav {
      animation: nav-shadown 1s linear both;
      animation-timeline: scroll();
      animation-range: 0 100px;
    }

    @keyframes nav-shadown {
      to {
        @apply shadow-lg ring-1 backdrop-blur dark:bg-gray-800/90 bg-white/50 ring-white/10;
      }
    }
  </style>
</header>
